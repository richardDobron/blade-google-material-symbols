{
    "name": "richarddobron/blade-google-material-symbols-500",
    "description": "A package to easily make use of Googles Material Design Symbols (500) in your Laravel Blade views.",
    "license": "MIT",
    "keywords": ["Blade", "Google", "Laravel", "Material", "Symbols"],
    "authors": [
        {
            "name": "Richard Dobroň"
        }
    ],
    "homepage": "https://github.com/richardDobron/blade-google-material-symbols-500",
    "require": {
        "php": "^7.4|^8.0"
    },
    "require-dev": {
        "ext-dom": "*",
        "ext-fileinfo": "*",
        "blade-ui-kit/blade-icons": "^1.1",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.0|^10.5|^11.0|^12.0",
        "spatie/phpunit-snapshot-assertions": "^2.0|^3.0|^4.0|^5.0",
        "friendsofphp/php-cs-fixer": "^3.2.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "dobron\\BladeMaterialSymbols\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always --testdox",
        "check-style": "php-cs-fixer fix --using-cache=no --diff --dry-run --ansi",
        "fix-style": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "dobron\\BladeMaterialSymbols\\BladeGoogleMaterialDesignSymbols100ServiceProvider"
            ]
        }
    }
}
